{
  "productName": "Mim",
  "version": "1.0.8",
  "identifier": "com.mim.app",
  "build": {
    "frontendDist": "frontend/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "frontend" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "frontend" }
  },
  "app": {
    "windows": [
      {
        "title": "Mim — Photo Library",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["/**", "C:\\**", "D:\\**", "E:\\**", "F:\\**", "$HOME\\**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "plugins": {
    "fs": {},
    "shell": {
      "open": true
    },
    "updater": {
      "active": false,
      "dialog": true,
      "endpoints": [
        "https://github.com/tonybenoy/mim/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
